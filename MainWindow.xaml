<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:StockTradingRecord"
        xmlns:System="clr-namespace:System;assembly=mscorlib" x:Class="StockTradingRecord.MainWindow"
        mc:Ignorable="d"
        Title="StockTradingRecord" Width="1220" Height="830" ResizeMode="CanMinimize" WindowStartupLocation="CenterScreen"  WindowState="Normal" Loaded="Window_Loaded"  Closing="Window_Closing">
    <Grid Margin="-1,0,1,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="0.15*"/>
            <RowDefinition Height="0.55*"/>
            <RowDefinition Height="0.15*"/>
            <RowDefinition Height="0.55*"/>
            <RowDefinition Height="0.55*"/>
            <RowDefinition Height="0.15*"/>
            <RowDefinition Height="10*"/>
            <RowDefinition Height="0.15*"/>
            <RowDefinition Height="0.8*"/>
            <RowDefinition Height="0.15*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" BorderBrush="Gray" BorderThickness="3" Height="3"/>
        <WrapPanel Grid.Row="1">
            <Label Content="开始日期:" FontSize="10" HorizontalAlignment="Left" Margin="10,5,0,0" VerticalAlignment="Top" Width="55"  Height="28"/>
            <DatePicker x:Name="datePickerStart"  SelectedDate="{x:Null}"   HorizontalAlignment="Left" FontSize="10" Margin="0,5,0,0" VerticalAlignment="Top" Width="90" Height="19">
                <DatePicker.LayoutTransform>
                    <ScaleTransform  ScaleX="1.5" ScaleY="1.5"/>
                </DatePicker.LayoutTransform>
            </DatePicker>
            <Label Content="结束日期:" FontSize="10" HorizontalAlignment="Left" Margin="10,5,0,0" VerticalAlignment="Top" Width="55"  Height="28"/>
            <DatePicker x:Name="datePickerEnd"  SelectedDate="{x:Null}"   HorizontalAlignment="Left" FontSize="10" Margin="0,5,0,0" VerticalAlignment="Top" Width="90" Height="19">
                <DatePicker.LayoutTransform>
                    <ScaleTransform  ScaleX="1.5" ScaleY="1.5"/>
                </DatePicker.LayoutTransform>
            </DatePicker>
            <Label Content="股票名称:" FontSize="10" HorizontalAlignment="Left" Margin="10,5,0,0" VerticalAlignment="Top" Width="55"  Height="28"/>
            <TextBox x:Name="tboxStockName"  Text="" Margin="0,5,0,0" FontSize="16" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" HorizontalAlignment="Left"  VerticalAlignment="Top" Width="130"  Height="28"/>
            <Label Content="股票代码:" FontSize="10" HorizontalAlignment="Left" Margin="10,5,0,0" VerticalAlignment="Top" Width="55"  Height="28"/>
            <TextBox x:Name="tboxStockCode"  Text="" Margin="0,5,0,0" FontSize="16" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" HorizontalAlignment="Left" VerticalAlignment="Top" Width="130"  Height="28"/>
            <Label Content="交易类型:" Visibility="Collapsed" FontSize="10" HorizontalAlignment="Left" Margin="10,5,0,0" VerticalAlignment="Top" Width="55"  Height="28"/>
            <ComboBox Visibility="Collapsed" Name="cboxQueryTradeType" Width="55" Margin="0,5,0,0"  HorizontalContentAlignment="Center" VerticalContentAlignment="Center" FontSize="11"  Height="28">
                <ComboBoxItem Tag="4"  Content="清仓"/>
                <ComboBoxItem Tag="3"  Content="卖出"/>
                <ComboBoxItem Tag="2"  Content="买入"/>
                <ComboBoxItem Tag="1"  Content="建仓"/>
            </ComboBox>
            <Label Content="查询时间:" FontSize="10" HorizontalAlignment="Left" Margin="10,5,0,0" VerticalAlignment="Top" Width="55"  Height="28"/>
            <ComboBox  Name="cboxQueryTradeDate" Width="65" Margin="0,5,0,0"  HorizontalContentAlignment="Center" VerticalContentAlignment="Center" FontSize="11" Height="28" SelectionChanged="cboxQueryTradeDate_SelectionChanged">
                <ComboBoxItem Tag="0"  Content="" />
                <ComboBoxItem Tag="1"  Content="近一月" IsSelected="True"/>
                <ComboBoxItem Tag="2"  Content="近三月"/>
                <ComboBoxItem Tag="3"  Content="近半年"/>
                <ComboBoxItem Tag="4"  Content="近一年"/>
                <ComboBoxItem Tag="5"  Content="近三年"/>
                <ComboBoxItem Tag="5"  Content="近五年"/>
                <ComboBoxItem Tag="5"  Content="近十年"/>
            </ComboBox>
            <Button Content="查询" x:Name="btnQuery" Click="btnQuery_Click" Background="#1C86EE" Foreground="White" FontSize="15" FontWeight="Bold" HorizontalAlignment="Left" Margin="10,5,0,0" VerticalAlignment="Top" Width="55"  Height="28"/>
        </WrapPanel>
        <Border Grid.Row="2" BorderBrush="Gray" BorderThickness="3" Height="3"/>
        <WrapPanel Grid.Row="3">
            <Label Content="股票名称:" FontSize="10" HorizontalAlignment="Left" Margin="10,5,0,0" VerticalAlignment="Top" Width="55"  Height="28"/>
            <TextBox x:Name="tboxAddStockName"  Text="" FontSize="16" Margin="0,5,0,0" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" HorizontalAlignment="Left" VerticalAlignment="Top" Width="130"  Height="28"/>
            <Label Content="股票代码:" FontSize="10" HorizontalAlignment="Left" Margin="30,5,0,0" VerticalAlignment="Top" Width="55"  Height="28"/>
            <TextBox x:Name="tboxAddStockCode"  Text="" Margin="0,5,0,0" FontSize="16" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" HorizontalAlignment="Left" VerticalAlignment="Top" Width="130"  Height="28"/>
        </WrapPanel>
        <WrapPanel Grid.Row="4">
            <Label Content="交易日期:" FontSize="10" HorizontalAlignment="Left" Margin="10,5,0,0" VerticalAlignment="Top" Width="55"  Height="28"/>
            <DatePicker x:Name="dateTradePicker"  SelectedDate="{x:Static System:DateTime.Now}"   HorizontalAlignment="Left" FontSize="10" Margin="0,5,0,0" VerticalAlignment="Top" Width="90" Height="19">
                <DatePicker.LayoutTransform>
                    <ScaleTransform  ScaleX="1.5" ScaleY="1.5"/>
                </DatePicker.LayoutTransform>
            </DatePicker>
            <Label Content="交易类型:" FontSize="10" HorizontalAlignment="Left" Margin="30,5,0,0" VerticalAlignment="Top" Width="55"  Height="28"/>
            <ComboBox  Name="cboxTradeType" Width="55" Margin="0,5,0,0"  HorizontalContentAlignment="Center" VerticalContentAlignment="Center" FontSize="11" SelectionChanged="cboxTradeType_SelectionChanged"  Height="28">
                <ComboBoxItem Tag="1"  Content="建仓"/>
                <ComboBoxItem Tag="2"  Content="买入"/>
                <ComboBoxItem Tag="3"  Content="卖出"/>
                <ComboBoxItem Tag="4"  Content="清仓"/>
            </ComboBox>
            <Label Content="交易价格:" FontSize="10" HorizontalAlignment="Left" Margin="30,5,0,0" VerticalAlignment="Top" Width="55"  Height="28"/>
            <TextBox x:Name="tboxBuyPrice"  Text="" FontSize="10" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" HorizontalAlignment="Left" Margin="0,5,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="80"  Height="28"/>
            <Label Content="交易数量:" FontSize="10" HorizontalAlignment="Left" Margin="30,5,0,0" VerticalAlignment="Top" Width="55"  Height="28"/>
            <TextBox x:Name="tboxBuyShares"  Text="" FontSize="10" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" HorizontalAlignment="Left" Margin="0,5,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="80"  Height="28"/>
            <Label Content="盈亏金额:" FontSize="10" HorizontalAlignment="Left" Margin="30,5,0,0" VerticalAlignment="Top" Width="55"  Height="28"/>
            <TextBox x:Name="tboxProfitLoss"  Text="" FontSize="10" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" HorizontalAlignment="Left" Margin="0,5,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="80"  Height="28"/>
            <Button Content="新增" x:Name="btnAdd" Click="btnAdd_Click" Background="#1C86EE" Foreground="White" FontSize="15" FontWeight="Bold" HorizontalAlignment="Left" Margin="20,5,0,0" VerticalAlignment="Top" Width="55"  Height="28"/>
            <Button Content="重置" x:Name="btnReset" Click="btnReset_Click" Background="#1C86EE" Foreground="White" FontSize="15" FontWeight="Bold"  Margin="20,5,0,0" HorizontalAlignment="Left" VerticalAlignment="Center" Width="55"  Height="28"/>
        </WrapPanel>
        <Border Grid.Row="5" BorderBrush="Gray" BorderThickness="3" Height="3"/>
        <DataGrid  Grid.Row="6" EnableRowVirtualization="True" x:Name="dataGridRecords"  AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True" FontSize="10" Margin="10,10,10,10" HeadersVisibility="Column" ScrollViewer.VerticalScrollBarVisibility="Visible"   RowHeaderWidth="0" LoadingRow="dataGridRecords_LoadingRow">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="{x:Type DataGridColumnHeader}">
                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                    <Setter Property="FontSize" Value="16"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.RowStyle>
                <Style TargetType="{x:Type DataGridRow}">
                    <Setter Property="HorizontalAlignment" Value="Center"/>
                    <Setter Property="VerticalAlignment" Value="Center"/>
                    <Setter Property="MaxHeight" Value="33"/>
                    <Setter Property="MinHeight" Value="33"/>
                    <Setter Property="FontSize" Value="15"/>
                    <EventSetter Event="UIElement.GotFocus" Handler="DataGridRow_GotFocus"/>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="序号"  Width="0.5*" Binding="{Binding Header, RelativeSource={RelativeSource AncestorType={x:Type DataGridRow}, Mode=FindAncestor}}" >
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="{x:Type TextBlock}">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="股票id" Binding="{Binding StockId}" Width="*" Visibility="Hidden" />

                <DataGridTextColumn Header="股票名称" Binding="{Binding StockName}" Width="*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="{x:Type TextBlock}">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTemplateColumn Header="复制名称" Width ="0.7*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="btnCopyStockName" Margin="15,0,0,0" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Content="复制" Width="50" Height="20"  FontSize="10" Background="#1C86EE" Foreground="White" Click="btnCopyStockName_Click"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="股票代码" Binding="{Binding StockCode}" Width="*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="{x:Type TextBlock}">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTemplateColumn Header="复制代码" Width ="0.7*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="btnCopyStockCode" Margin="15,0,0,0" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Content="复制" Width="50" Height="20"  FontSize="10" Background="#1C86EE" Foreground="White" Click="btnCopyStockCode_Click"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="交易日期" Binding="{Binding TradeDate, StringFormat=yyyy-MM-dd}" Width="*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="{x:Type TextBlock}">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="交易类型" Binding="{Binding TradeType}" Width="*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="{x:Type TextBlock}">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                    <DataGridTextColumn.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Foreground" Value="Black"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding TradeType}" Value="建仓">
                                    <Setter Property="Foreground" Value="Green"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding TradeType}" Value="清仓">
                                    <Setter Property="Foreground" Value="Red"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.CellStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="交易价格" Binding="{Binding TradePrice}" Width="*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="{x:Type TextBlock}">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="交易股数" Binding="{Binding TradeShares}" Width="*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="{x:Type TextBlock}">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="盈亏金额" Binding="{Binding ProfitLossAmount}" Width="*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="{x:Type TextBlock}">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTemplateColumn Header="操作" Width ="0.7*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="btnDelete" Margin="15,0,0,0" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Content="删除" Width="50" Height="20"  FontSize="10" Background="#1C86EE" Foreground="White" Click="btnDelete_Click"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
        <Border Grid.Row="7" BorderBrush="Gray" BorderThickness="3" Height="3"/>
        <WrapPanel Grid.Row="8">
            <Label Content="总盈亏金额:" FontSize="12" HorizontalAlignment="Left" Margin="915,0,0,0" VerticalAlignment="Top" Width="72"  Height="28"/>
            <TextBox x:Name="tboxProfitLossAmount" IsReadOnly="True" Text="" FontSize="13" Margin="990,-29,0,0"  VerticalContentAlignment="Center" HorizontalContentAlignment="Center" HorizontalAlignment="Left"  VerticalAlignment="Top" Width="80"  Height="28"/>
        </WrapPanel>
    </Grid>
</Window>
