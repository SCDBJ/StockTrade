<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:StockTradingRecord"
        xmlns:System="clr-namespace:System;assembly=mscorlib" x:Class="StockTradingRecord.MainWindow"
        mc:Ignorable="d"
        Title="StockTradingRecord" Height="900" Width="1240" WindowStartupLocation="CenterScreen"  WindowState="Normal" Loaded="Window_Loaded"  Closing="Window_Closing">
    <Grid Margin="-1,0,1,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="0.3*"/>
            <RowDefinition Height="0.7*"/>
            <RowDefinition Height="0.3*"/>
            <RowDefinition Height="0.7*"/>
            <RowDefinition Height="0.7*"/>
            <RowDefinition Height="0.3*"/>
            <RowDefinition Height="9*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" BorderBrush="Gray" BorderThickness="3" Height="3"/>
        <WrapPanel Grid.Row="1">
            <Label Content="开始日期:" FontSize="15" HorizontalAlignment="Left" Margin="16,10,0,0" VerticalAlignment="Top" Width="73" Height="35"/>
            <DatePicker x:Name="datePickerStart"  SelectedDate="{x:Static System:DateTime.Now}"   HorizontalAlignment="Left" FontSize="11" Margin="8,10,0,0" VerticalAlignment="Top" Width="90" Height="22">
                <DatePicker.LayoutTransform>
                    <ScaleTransform  ScaleX="1.5" ScaleY="1.5"/>
                </DatePicker.LayoutTransform>
            </DatePicker>
            <Label Content="结束日期:" FontSize="15" HorizontalAlignment="Left" Margin="13,10,0,0" VerticalAlignment="Top" Width="73" Height="34"/>
            <DatePicker x:Name="datePickerEnd"  SelectedDate="{x:Static System:DateTime.Now}"   HorizontalAlignment="Left" FontSize="11" Margin="0,10,0,0" VerticalAlignment="Top" Width="90" Height="22">
                <DatePicker.LayoutTransform>
                    <ScaleTransform  ScaleX="1.5" ScaleY="1.5"/>
                </DatePicker.LayoutTransform>
            </DatePicker>
            <Label Content="股票名称:" FontSize="15" HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top" Width="73" Height="34"/>
            <TextBox x:Name="tboxStockName"  Text="" FontSize="16" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" HorizontalAlignment="Left" Margin="10,10,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="163" Height="34"/>
            <Label Content="股票代码:" FontSize="15" HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top" Width="73" Height="34"/>
            <TextBox x:Name="tboxStockCode"  Text="" FontSize="16" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" HorizontalAlignment="Left" Margin="10,10,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="163" Height="34"/>
            <Button Content="查询" x:Name="btnQuery" Click="btnQuery_Click" Background="#1C86EE" Foreground="White" FontSize="19" FontWeight="Bold" HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top" Width="73" Height="34"/>
        </WrapPanel>
        <Border Grid.Row="2" BorderBrush="Gray" BorderThickness="3" Height="3"/>
        <WrapPanel Grid.Row="3">
          
            <Label Content="股票名称:" FontSize="15" HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top" Width="73" Height="34"/>
            <TextBox x:Name="tboxAddStockName"  Text="" FontSize="16" Margin="10,10,0,0" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" HorizontalAlignment="Left" TextWrapping="Wrap" VerticalAlignment="Top" Width="163" Height="34"/>
            <Label Content="股票代码:" FontSize="15" HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top" Width="73" Height="34"/>
            <TextBox x:Name="tboxAddStockCode"  Text="" FontSize="16" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" HorizontalAlignment="Left" Margin="10,10,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="163" Height="34"/>
        </WrapPanel>
        <WrapPanel Grid.Row="4">
            <Label Content="交易日期:" FontSize="15" HorizontalAlignment="Left" Margin="13,10,0,0" VerticalAlignment="Top" Width="73" Height="34"/>
            <DatePicker x:Name="dateTradePicker"  SelectedDate="{x:Static System:DateTime.Now}"   HorizontalAlignment="Left" FontSize="11" Margin="0,10,0,0" VerticalAlignment="Top" Width="90" Height="22">
                <DatePicker.LayoutTransform>
                    <ScaleTransform  ScaleX="1.5" ScaleY="1.5"/>
                </DatePicker.LayoutTransform>
            </DatePicker>
            <Label Content="交易类型:" FontSize="15" HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top" Width="73" Height="34"/>
            <ComboBox  Name="cboxTradeType" Width="60" Margin="15,10,0,0"  HorizontalContentAlignment="Center" VerticalContentAlignment="Center" FontSize="15" >
                <ComboBoxItem Content="建仓"/>
                <ComboBoxItem Content="买入"/>
                <ComboBoxItem Content="卖出"/>
                <ComboBoxItem Content="清仓"/>
            </ComboBox>
            <Label Content="交易价格:" FontSize="15" HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top" Width="73" Height="34"/>
            <TextBox x:Name="tboxBuyPrice"  Text="" FontSize="15" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" HorizontalAlignment="Left" Margin="10,10,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="80" Height="34"/>
            <Label Content="交易数量:" FontSize="15" HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top" Width="73" Height="34"/>
            <TextBox x:Name="tboxBuyShares"  Text="" FontSize="15" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" HorizontalAlignment="Left" Margin="10,10,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="80" Height="34"/>
            <Label Content="盈亏金额:" FontSize="15" HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top" Width="73" Height="34"/>
            <TextBox x:Name="tboxProfitLoss"  Text="" FontSize="15" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" HorizontalAlignment="Left" Margin="10,10,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="80" Height="34"/>
            <Button Content="新增" x:Name="btnAdd" Click="btnAdd_Click" Background="#1C86EE" Foreground="White" FontSize="19" FontWeight="Bold" HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top" Width="73" Height="34"/>
        </WrapPanel>
        <Border Grid.Row="5" BorderBrush="Gray" BorderThickness="3" Height="3"/>
        <StackPanel Grid.Row="6">
            <DataGrid x:Name="dataGridRecords" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True" FontSize="15" Margin="10,10,10,10" HeadersVisibility="Column" Width="1204" ScrollViewer.VerticalScrollBarVisibility="Visible"  RowHeaderWidth="0" LoadingRow="dataGridRecords_LoadingRow">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="{x:Type DataGridColumnHeader}">
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="FontSize" Value="17"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.RowStyle>
                    <Style TargetType="{x:Type DataGridRow}">
                        <Setter Property="HorizontalAlignment" Value="Center"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="股票id" Binding="{Binding StockId}" Width="*" Visibility="Hidden" />
                    <DataGridTextColumn Header="序号"  Width="*" Binding="{Binding Header, RelativeSource={RelativeSource AncestorType={x:Type DataGridRow}, Mode=FindAncestor}}" >
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="{x:Type TextBlock}">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="股票名称" Binding="{Binding StockName}" Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="{x:Type TextBlock}">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="股票代码" Binding="{Binding StockCode}" Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="{x:Type TextBlock}">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="交易日期" Binding="{Binding TradeDate, StringFormat=yyyy-MM-dd}" Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="{x:Type TextBlock}">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="交易类型" Binding="{Binding TradeType}" Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="{x:Type TextBlock}">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="交易价格" Binding="{Binding TradePrice}" Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="{x:Type TextBlock}">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="交易股数" Binding="{Binding TradeShares}" Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="{x:Type TextBlock}">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="交易类型" Binding="{Binding TradeType}" Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="{x:Type TextBlock}">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="盈亏金额" Binding="{Binding ProfitLossAmount}" Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="{x:Type TextBlock}">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>
    </Grid>
</Window>
